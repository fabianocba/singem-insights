# SINGEM - ambiente de desenvolvimento (Docker local)
# Fonte oficial de ambiente para docker/dev/docker-compose.dev.yml
SINGEM_DB_NAME=singem
SINGEM_DB_USER=adm
SINGEM_DB_PASSWORD=Singem@12345
SINGEM_CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000,http://127.0.0.1:3000
SINGEM_ADMIN_LOGIN=adm
SINGEM_ADMIN_PASSWORD=Singem@12345
BACKEND_PORT_EXTERNAL=3000
FRONTEND_PORT_EXTERNAL=8000
AI_PORT_EXTERNAL=8010
JWT_SECRET=dev_secret_do_not_use_in_production_32chars!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
