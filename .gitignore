# ============================================================
# SINGEM — .gitignore (ambiente determinístico / máquina descartável)
# Fonte da verdade: repositório e arquivos versionados
# ============================================================

# Dependências locais
node_modules/
server/node_modules/

# Build e cache local
dist/
build/
.next/
.cache/
.turbo/

# Python cache
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# Testes / cobertura
coverage/
.nyc_output/

# Arquivos temporários
*.tmp
*.temp
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ambiente local (não versionar segredos)
.env
.env.local
.env.*.local
server/.env
server/.env.development
server/.env.production
server/.env.bak

# IDE / OS
.idea/
.DS_Store
Thumbs.db
desktop.ini

# VS Code: manter configuração oficial versionada
.vscode/*.log

# Sessão local de scripts
.dev-session.json

# Artefatos gerados de auditoria/qualidade
SCAN_REPORT.txt
.lint-output.txt
quality-report.json

# Dados reais e artefatos operacionais locais
01_EMPENHOS/
02_NOTAS_FISCAIS/
03_RELATORIOS/
04_BACKUPS/*
!04_BACKUPS/README.md
05_ANEXOS/
data/exemplos/
storage/
logs/
server/logs/

# Dumps e backups locais
04_BACKUPS/*.json
04_BACKUPS/**/*.json
data/backups/
**/backups/
*.dump
*.dmp
*.bak
*.backup
*.sql.gz
*.tar.gz
*.zip

# Certificados locais
docker/ssl/
certbot/

