# IFDESK - Configuração de Cache
# Força revalidação de arquivos JavaScript e CSS

<IfModule mod_headers.c>
    # Desabilita cache para arquivos JavaScript
    <FilesMatch "\.(js)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>

    # Desabilita cache para arquivos CSS
    <FilesMatch "\.(css)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>

    # Desabilita cache para arquivos HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires 0
    </FilesMatch>
</IfModule>

# Se mod_headers não estiver disponível, use mod_expires
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/javascript "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
    ExpiresByType text/css "access plus 0 seconds"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>
