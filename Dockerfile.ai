# ============================================================
# SINGEM AI Core — Dockerfile (CPU + GPU)
# Base: python:3.12-slim  |  Entry: python run.py
# Perfil Docker: "ai" (opcional no docker compose up)
#
# Build CPU (padrao):
#   docker build -f Dockerfile.ai -t singem-ai-core .
#
# Build GPU (NVIDIA CUDA):
#   docker build -f Dockerfile.ai --build-arg GPU_ENABLED=true \
#     -t singem-ai-core:gpu .
# ============================================================

# ---- Argumento de build para GPU --------------------------
ARG GPU_ENABLED=false

# ---- Stage: base CPU -------------------------------------
FROM python:3.12-slim AS base-false

# ---- Stage: base GPU (NVIDIA CUDA 12.4 + cuDNN) ----------
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04 AS base-true

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        software-properties-common \
    && add-apt-repository -y ppa:deadsnakes/ppa \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.12 \
        python3.12-dev \
        python3-pip \
    && ln -sf /usr/bin/python3.12 /usr/bin/python \
    && ln -sf /usr/bin/python3.12 /usr/bin/python3 \
    && rm -rf /var/lib/apt/lists/*

# ---- Stage: deps -----------------------------------------
FROM base-${GPU_ENABLED} AS deps

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libpq5 \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY singem-ai/requirements.txt ./
RUN python -m pip install -r requirements.txt

# Extras GPU (PyTorch CUDA + sentence-transformers)
ARG GPU_ENABLED=false
RUN if [ "$GPU_ENABLED" = "true" ]; then \
        python -m pip install \
            torch --index-url https://download.pytorch.org/whl/cu124 && \
        python -m pip install sentence-transformers; \
    fi

# ---- Stage: runtime --------------------------------------
FROM deps AS runtime

RUN addgroup --system --gid 1001 singem \
    && adduser --system --uid 1001 --ingroup singem --no-create-home singem

WORKDIR /app

COPY singem-ai/ ./

RUN chown -R singem:singem /app

USER singem

EXPOSE 8010

ARG GPU_ENABLED=false
LABEL org.opencontainers.image.title="SINGEM AI Core" \
      org.opencontainers.image.description="FastAPI AI service for SINGEM" \
      org.opencontainers.image.source="https://github.com/fabianocba/SINGEM" \
      singem.gpu.enabled="${GPU_ENABLED}"

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD python -c "import json,urllib.request,sys; data=json.load(urllib.request.urlopen('http://localhost:8010/ai/health', timeout=5)); sys.exit(0 if data.get('ok') else 1)"

CMD ["python", "run.py"]
