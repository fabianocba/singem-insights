# ==================================================
# SINGEM - exemplo de ambiente (server)
# ==================================================

# API de Dados Abertos Compras.gov.br
# Padrão oficial (sem token obrigatório)
COMPRAS_API_BASE_URL=https://dadosabertos.compras.gov.br
COMPRAS_API_TIMEOUT_MS=30000
COMPRAS_API_MAX_RETRIES=2
COMPRAS_API_RETRY_BASE_DELAY_MS=400

# Opcional: use somente se um ambiente específico exigir autenticação
COMPRAS_API_TOKEN=

# SINGEM AI Core (proxy interno opcional)
AI_CORE_ENABLED=true
AI_CORE_BASE_URL=http://ai-core:8010
AI_CORE_API_PREFIX=/ai
AI_CORE_TIMEOUT_MS=15000
AI_CORE_HEALTH_TIMEOUT_MS=2500
AI_CORE_INTERNAL_TOKEN=change-me
AI_CORE_INTERNAL_TOKEN_HEADER=x-internal-token
AI_CORE_AUTO_REINDEX_ON_MUTATION=true
AI_CORE_REINDEX_DEBOUNCE_MS=1500

# ==================================================
# Login Único Gov.br (OAuth2 + PKCE)
# Referência: https://manual-roteiro-integracao-login-unico.servicos.gov.br/
# ==================================================
GOVBR_ENABLED=false
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=http://localhost:3000/api/auth/govbr/callback
GOVBR_ISSUER=https://sso.acesso.gov.br
GOVBR_AUTO_CREATE_USER=false
# Scopes (padrão: openid email profile govbr_confiabilidades govbr_empresa)
# GOVBR_SCOPES=openid email profile govbr_confiabilidades govbr_empresa
