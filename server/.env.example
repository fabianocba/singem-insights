# ===========================================
# SINGEM - Sistema Institucional de Gestão de Material
# IF Baiano - Configuração de Ambiente
# ===========================================
# Copie para .env e preencha os valores

# ==========================================
# SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ==========================================
# POSTGRESQL
# ==========================================
# URL de conexão completa (prioridade)
DATABASE_URL=postgresql://singem_user:sua_senha@localhost:5432/singem

# Ou variáveis individuais (fallback)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=singem
DB_USER=singem_user
DB_PASSWORD=sua_senha_segura

# ==========================================
# JWT - Autenticação
# ==========================================
JWT_SECRET=sua_chave_secreta_muito_longa_minimo_32_caracteres_aleatorios
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# SEFAZ (NF-e) - Opcional
# ==========================================
SEFAZ_AMBIENTE=producao
CERTIFICADO_PATH=
CERTIFICADO_SENHA=

# ==========================================
# ADMIN BOOTSTRAP (Primeiro Usuário)
# ==========================================
# Usado pelo script: node scripts/seed-admin.js
ADMIN_LOGIN=admin
ADMIN_NOME=Administrador SINGEM
ADMIN_EMAIL=admin@ifbaiano.edu.br
ADMIN_PASSWORD=MudarNaPrimeiraExecucao123!

# ==========================================
# GOV.BR - Login Único (OAuth2/OIDC)
# ==========================================
# Documentação: https://manual-roteiro-integracao-login-unico.servicos.gov.br/
# Ambiente de homologação: https://sso.staging.acesso.gov.br
# Ambiente de produção: https://sso.acesso.gov.br
GOVBR_ENABLED=false
GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
GOVBR_REDIRECT_URI=http://localhost:3000/api/auth/govbr/callback
GOVBR_ISSUER=https://sso.staging.acesso.gov.br
GOVBR_SCOPES=openid email profile govbr_confiabilidades

# ==========================================
# SERPRO - Integrações (Futuro)
# ==========================================
# APIs: CNPJ, CPF, etc
SERPRO_ENABLED=false
SERPRO_BASE_URL=https://gateway.apiserpro.serpro.gov.br
SERPRO_API_KEY=
SERPRO_CONSUMER_SECRET=

# ==========================================
# SERPROID - Login com Certificado Digital (OAuth2 + PKCE)
# ==========================================
# Homologação: https://hom.serproid.serpro.gov.br
# Produção:    https://serproid.serpro.gov.br
SERPROID_ENABLED=false
SERPROID_CLIENT_ID=
SERPROID_CLIENT_SECRET=
SERPROID_REDIRECT_URI=http://localhost:3000/api/auth/serproid/callback
SERPROID_BASE_URL=https://hom.serproid.serpro.gov.br
SERPROID_AUTO_CREATE_USER=false

# ==========================================
# CATMAT - Catálogo de Materiais (Futuro)
# ==========================================
# Importação de materiais do catálogo federal
CATMAT_ENABLED=false
CATMAT_IMPORT_PATH=./data/catmat
