# COMPRAS.GOV.BR (DADOS ABERTOS) - INTEGRAÇÃO
COMPRASGOV_BASE_URL=https://dadosabertos.compras.gov.br
COMPRASGOV_TIMEOUT_MS=10000
COMPRASGOV_MAX_RETRIES=3
COMPRASGOV_RETRY_BASE_DELAY_MS=400
COMPRASGOV_RATE_LIMIT_MS=250

COMPRASGOV_CACHE_ENABLED=true
COMPRASGOV_CACHE_TTL_CATALOGO_SECONDS=86400
COMPRASGOV_CACHE_TTL_PESQUISA_SECONDS=21600
COMPRASGOV_CACHE_TTL_DEFAULT_SECONDS=3600

COMPRASGOV_MAX_PAGE_SIZE=500
COMPRASGOV_MAX_AUTO_PAGES=20
COMPRASGOV_AUDIT_ENABLED=true
COMPRASGOV_SNAPSHOT_ENABLED=true

COMPRASGOV_ENDPOINT_CATALOGO_MATERIAL_ITENS=/modulo-material/4_consultarItemMaterial
COMPRASGOV_ENDPOINT_CATALOGO_MATERIAL_GRUPOS=/modulo-material/1_consultarGrupoMaterial
COMPRASGOV_ENDPOINT_CATALOGO_MATERIAL_CLASSES=/modulo-material/2_consultarClasseMaterial

COMPRASGOV_ENDPOINT_CATALOGO_SERVICO_ITENS=/modulo-servico/6_consultarItemServico
COMPRASGOV_ENDPOINT_CATALOGO_SERVICO_GRUPOS=/modulo-servico/3_consultarGrupoServico
COMPRASGOV_ENDPOINT_CATALOGO_SERVICO_CLASSES=/modulo-servico/4_consultarClasseServico

COMPRASGOV_ENDPOINT_PESQUISA_PRECO_MATERIAL=/modulo-pesquisa-preco/1_consultarMaterial
COMPRASGOV_ENDPOINT_PESQUISA_PRECO_SERVICO=/modulo-pesquisa-preco/3_consultarServico

COMPRASGOV_ENDPOINT_UASG=/modulo-uasg/1_consultarUasg
COMPRASGOV_ENDPOINT_FORNECEDOR=/modulo-fornecedor/1_consultarFornecedor
COMPRASGOV_ENDPOINT_CONTRATACOES=/modulo-contratacoes/1_consultarContratacoes_PNCP_14133
COMPRASGOV_ENDPOINT_ARP=/modulo-arp/2_consultarARPItem
COMPRASGOV_ENDPOINT_CONTRATOS=/modulo-contratos/1_consultarContratos
COMPRASGOV_ENDPOINT_LEGADO_LICITACOES=/modulo-legado/1_consultarLicitacao
COMPRASGOV_ENDPOINT_LEGADO_ITENS=/modulo-legado/2_consultarItemLicitacao
COMPRASGOV_ENDPOINT_OCDS=/modulo-ocds/1_releases

# DADOS.GOV.BR (CKAN API)
DADOSGOV_CKAN_BASE_URL=https://dados.gov.br/api/3/action
DADOSGOV_CKAN_TIMEOUT_MS=12000
DADOSGOV_CKAN_CACHE_ENABLED=true
DADOSGOV_CKAN_CACHE_TTL_SECONDS=300
DADOSGOV_CKAN_MAX_RETRIES=3
DADOSGOV_CKAN_RETRY_BASE_DELAY_MS=400
DADOSGOV_CKAN_MAX_DOWNLOAD_BYTES=20971520

# INTEGRAÇÕES (FASE 2)
INTEGRACOES_AUDIT_ENABLED=true
INTEGRACOES_CACHE_ENABLED=true
INTEGRACOES_CACHE_TTL_CATALOGO_SECONDS=86400
INTEGRACOES_CACHE_TTL_PESQUISA_SECONDS=21600
INTEGRACOES_CACHE_TTL_FORNECEDOR_UASG_SECONDS=43200
INTEGRACOES_SYNC_MAX_PAGES=20
INTEGRACOES_SYNC_PAGE_SIZE=100
PRICE_SNAPSHOT_ENABLED=true
