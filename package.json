{
  "name": "singem",
  "version": "1.3.0",
  "description": "SINGEM - Sistema de Controle de Material (IF Baiano)",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "build": "npm run tailwind:build",
    "start": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start.ps1 -ProjectRoot .",
    "stop": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop.ps1 -ProjectRoot .",
    "rebuild": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/rebuild.ps1 -ProjectRoot .",
    "logs": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/logs.ps1 -ProjectRoot .",
    "deploy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/deploy.ps1 -ProjectRoot .",
    "version": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/version.ps1 -ProjectRoot .",
    "clean:legacy": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/clean-legacy.ps1 -ProjectRoot .",
    "seed:simulacao:dry": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/seed-simulacao-realista.ps1 -ProjectRoot .",
    "seed:simulacao": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/seed-simulacao-realista.ps1 -ProjectRoot . -Apply",
    "dev": "npm run start",
    "dev:start": "npm run start",
    "dev:stop": "npm run stop",
    "dev:rebuild": "npm run rebuild",
    "dev:deploy:vps": "npm run deploy",
    "dev:audit:vps": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/vps-docker-audit.ps1",
    "version:bump": "node ./scripts/bump-version.js",
    "scan:orphans": "node ./scripts/scan-refs.cjs",
    "serve": "node ./scripts/serve-dev.cjs --host 0.0.0.0 --port 8000 --directory .",
    "serve:dev": "node ./scripts/serve-dev.cjs --host 127.0.0.1 --port 8000 --directory .",
    "tailwind:build": "npx @tailwindcss/cli -i ./css/tailwind-source.css -o ./css/tailwind.css --minify",
    "tailwind:watch": "npx @tailwindcss/cli -i ./css/tailwind-source.css -o ./css/tailwind.css --watch",
    "lint": "eslint . --ext .js --max-warnings 60",
    "test": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/test-contracts.ps1 -ProjectRoot .",
    "test:contracts:direct": "npm --prefix server run test:contracts",
    "lint:fix": "eslint . --ext .js --fix",
    "smoke:nfe": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-importar-nfe.ps1",
    "smoke:nfe:real": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-importar-nfe.ps1 -UseRealBackend",
    "smoke:nfe:real:write": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/smoke-importar-nfe.ps1 -UseRealBackend -AllowWrite",
    "validate:almox": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/validate-almoxarifado-local.ps1",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "quality": "node ./scripts/quality-check.mjs",
    "validate:version": "node ./scripts/validate-version-sync.js"
  },
  "keywords": [
    "controle-material",
    "if-baiano",
    "indexeddb",
    "offline-first"
  ],
  "author": "IF Baiano",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
