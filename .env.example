# ============================================================
# SINGEM — .env.example (raiz)
#
# Arquivo de referência para padronização.
#
# Fluxo oficial:
#   Desenvolvimento Docker: use .env.dev
#   Produção VPS:           use docker/prod/.env.prod
# ============================================================

# Desenvolvimento
SINGEM_DB_NAME=singem
SINGEM_DB_USER=adm
SINGEM_DB_PASSWORD=Singem@12345
SINGEM_CORS_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:8000,http://127.0.0.1:3000
SINGEM_ADMIN_LOGIN=adm
SINGEM_ADMIN_PASSWORD=Singem@12345

# Produção (preencher antes de uso)
DB_NAME=singem
DB_USER=adm
DB_PASSWORD=
CORS_ORIGINS=
FRONTEND_URL=
JWT_SECRET=
ADMIN_PASSWORD=
REDIS_PASSWORD=
