# ============================================================
# SINGEM — .env.example
# Variáveis de ambiente para execução via Docker Compose
#
# Como usar:
#   cp .env.example .env
#   # Edite os valores sensíveis (JWT_SECRET, DB_PASSWORD, etc.)
#   docker compose up --build
# ============================================================

# ------ Banco de dados PostgreSQL -------------------------
DB_NAME=singem
DB_USER=adm
DB_PASSWORD=Singem@12345

# Porta expostas no host (0.0.0.0:5432 -> container:5432)
DB_PORT_EXTERNAL=5432

# ------ Backend Node.js -----------------------------------
NODE_ENV=development
TRUST_PROXY=false
API_BODY_LIMIT=10mb

# Portas mapeadas para o host
BACKEND_PORT_EXTERNAL=3000
FRONTEND_PORT_EXTERNAL=8000

# CORS: origens permitidas para acessar a API
# Em produção, substitua por domínio real (ex: https://meusite.com)
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# URL pública do frontend (usada em e-mails, redirects, etc.)
FRONTEND_URL=http://localhost:8000

# ------ JWT (TROCAR EM PRODUÇÃO!) -------------------------
# Mínimo 32 caracteres, usar gerador: openssl rand -hex 32
JWT_SECRET=change_this_secret_in_production_min32chars!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------ Admin inicial (criado automaticamente no 1º boot) -
ADMIN_LOGIN=admin
ADMIN_NOME=Administrador SINGEM
ADMIN_EMAIL=admin@ifbaiano.edu.br
ADMIN_PASSWORD=MudarNaPrimeiraExecucao123!

# ------ AI Core (opcional — profile "ai") -----------------
# Porta mapeada para host quando ai-core estiver ativo
AI_PORT_EXTERNAL=8010
AI_CORE_ENABLED=false
AI_CORE_INTERNAL_TOKEN=change-me
AI_CORE_TIMEOUT_MS=15000
AI_CORE_HEALTH_TIMEOUT_MS=2500
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
ENABLE_VECTOR_SEARCH=true

# ------ Redis (incluído por padrão) ----------------------
REDIS_PORT_EXTERNAL=6379

# ------ Integrações externas (desativas por padrão) ------
GOVBR_ENABLED=false
SERPRO_ENABLED=false
SERPROID_ENABLED=false
CATMAT_ENABLED=false
CATMAT_OBRIGATORIO=false

# ------ Compras.gov.br (dados abertos) -------------------
COMPRASGOV_BASE_URL=https://dadosabertos.compras.gov.br
COMPRASGOV_TIMEOUT_MS=10000
COMPRASGOV_MAX_RETRIES=3

# ------ SMTP (opcional) ----------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SINGEM <naoresponda@ifbaiano.edu.br>

# ------ SEFAZ (opcional) ---------------------------------
SEFAZ_AMBIENTE=producao
CERTIFICADO_PATH=
CERTIFICADO_SENHA=
