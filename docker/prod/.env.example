# ============================================================
# SINGEM — Variáveis de ambiente (PRODUÇÃO VPS)
#
# Como usar:
#   cp .env.example .env.prod
#   # PREENCHA TODOS os valores abaixo — campos marcados com
#   # "[OBRIGATÓRIO]" causam erro se vazios.
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
#
# Gerar secrets seguros:
#   openssl rand -hex 32          # JWT_SECRET
#   openssl rand -base64 32       # DB_PASSWORD, REDIS_PASSWORD
# ============================================================

# ------ Banco de dados PostgreSQL -------------------------
DB_NAME=singem
DB_USER=adm
DB_PASSWORD=                  # [OBRIGATÓRIO] Senha forte — gerar com: openssl rand -base64 32

# ------ Backend Node.js -----------------------------------
API_BODY_LIMIT=10mb

# ------ Frontend / Domínio --------------------------------
# [OBRIGATÓRIO] Domínio real do SINGEM
FRONTEND_URL=https://singem.ifbaiano.edu.br
FRONTEND_PORT_HTTP=80
FRONTEND_PORT_HTTPS=443

# ------ CORS ----------------------------------------------
# [OBRIGATÓRIO] Origens permitidas (sem barra final)
CORS_ORIGINS=https://singem.ifbaiano.edu.br

# ------ JWT -----------------------------------------------
# [OBRIGATÓRIO] Mínimo 32 caracteres — gerar com: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------ Admin inicial (criado no 1º boot) -----------------
ADMIN_LOGIN=adm
ADMIN_NOME=Administrador SINGEM
ADMIN_EMAIL=admin@ifbaiano.edu.br
ADMIN_PASSWORD=               # [OBRIGATÓRIO] Senha forte do admin

# ------ Redis ---------------------------------------------
REDIS_PASSWORD=               # [OBRIGATÓRIO] Gerar com: openssl rand -base64 24

# ------ TLS/SSL opcional via override ---------------------
# Se omitidos, o override usa os caminhos padrao da VPS:
#   /etc/letsencrypt/live/singem.cloud/fullchain.pem
#   /etc/letsencrypt/live/singem.cloud/privkey.pem
# SSL_CERT_FULLCHAIN_PATH=
# SSL_CERT_PRIVKEY_PATH=

# ------ AI Core (stack oficial Docker) ---------------------
AI_CORE_ENABLED=true
AI_CORE_API_PREFIX=/ai
AI_CORE_INTERNAL_TOKEN=       # [OBRIGATÓRIO se AI ativo] Gerar com: openssl rand -base64 32
GPU_ENABLED=false
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
ENABLE_VECTOR_SEARCH=true

# ------ Integrações externas ------------------------------
GOVBR_ENABLED=false
SERPRO_ENABLED=false
SERPROID_ENABLED=false
CATMAT_ENABLED=false
CATMAT_OBRIGATORIO=false

# ------ Compras.gov.br (dados abertos) -------------------
COMPRASGOV_BASE_URL=https://dadosabertos.compras.gov.br
COMPRASGOV_TIMEOUT_MS=10000
COMPRASGOV_MAX_RETRIES=3
COMPRASGOV_RETRY_BASE_DELAY_MS=400
COMPRASGOV_RATE_LIMIT_MS=250
COMPRASGOV_CACHE_ENABLED=true
COMPRASGOV_CACHE_TTL_CATALOGO_SECONDS=86400
COMPRASGOV_CACHE_TTL_PESQUISA_SECONDS=21600
COMPRASGOV_CACHE_TTL_FORNECEDOR_UASG_SECONDS=43200
COMPRASGOV_CACHE_TTL_DEFAULT_SECONDS=3600
COMPRASGOV_MAX_PAGE_SIZE=500
COMPRASGOV_MAX_AUTO_PAGES=20
COMPRASGOV_AUDIT_ENABLED=true
COMPRASGOV_SNAPSHOT_ENABLED=true

# ------ SMTP (notificações por e-mail) -------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SINGEM <naoresponda@ifbaiano.edu.br>

# ------ SEFAZ (NF-e) -------------------------------------
SEFAZ_AMBIENTE=producao
CERTIFICADO_PATH=
CERTIFICADO_SENHA=
