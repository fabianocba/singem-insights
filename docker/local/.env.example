# ============================================================
# SINGEM — Variáveis de ambiente (DESENVOLVIMENTO LOCAL)
#
# Como usar:
#   cp .env.example .env
#   docker compose up --build
#
# Valores padrão seguros para desenvolvimento.
# NÃO use estes valores em produção!
# ============================================================

# ------ Banco de dados PostgreSQL -------------------------
DB_NAME=singem
DB_USER=adm
DB_PASSWORD=Singem@12345
DB_PORT_EXTERNAL=5432

# ------ Backend Node.js -----------------------------------
BACKEND_PORT_EXTERNAL=3000
API_BODY_LIMIT=10mb

# ------ Frontend ------------------------------------------
FRONTEND_PORT_EXTERNAL=8000
FRONTEND_URL=http://localhost:8000

# ------ CORS ----------------------------------------------
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ------ JWT -----------------------------------------------
JWT_SECRET=dev_secret_do_not_use_in_production_32chars!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ------ Admin inicial -------------------------------------
ADMIN_LOGIN=admin
ADMIN_NOME=Administrador SINGEM
ADMIN_EMAIL=admin@ifbaiano.edu.br
ADMIN_PASSWORD=MudarNaPrimeiraExecucao123!

# ------ AI Core (opcional — ative com --profile ai) -------
AI_CORE_ENABLED=false
AI_CORE_API_PREFIX=/ai
AI_CORE_INTERNAL_TOKEN=dev-token-local
AI_PORT_EXTERNAL=8010
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSION=384
ENABLE_VECTOR_SEARCH=true

# ------ Redis ---------------------------------------------
REDIS_PORT_EXTERNAL=6379

# ------ Integrações externas (desativadas por padrão) -----
GOVBR_ENABLED=false
SERPRO_ENABLED=false
SERPROID_ENABLED=false
CATMAT_ENABLED=false
CATMAT_OBRIGATORIO=false

# ------ Compras.gov.br (dados abertos) -------------------
COMPRASGOV_BASE_URL=https://dadosabertos.compras.gov.br
COMPRASGOV_TIMEOUT_MS=10000
COMPRASGOV_MAX_RETRIES=3
COMPRASGOV_RETRY_BASE_DELAY_MS=400
COMPRASGOV_RATE_LIMIT_MS=250
COMPRASGOV_CACHE_ENABLED=true
COMPRASGOV_CACHE_TTL_CATALOGO_SECONDS=86400
COMPRASGOV_CACHE_TTL_PESQUISA_SECONDS=21600
COMPRASGOV_CACHE_TTL_FORNECEDOR_UASG_SECONDS=43200
COMPRASGOV_CACHE_TTL_DEFAULT_SECONDS=3600
COMPRASGOV_MAX_PAGE_SIZE=500
COMPRASGOV_MAX_AUTO_PAGES=20
COMPRASGOV_AUDIT_ENABLED=true
COMPRASGOV_SNAPSHOT_ENABLED=true

# ------ SMTP (opcional) ----------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
