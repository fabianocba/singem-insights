# SINGEM AI Core
APP_NAME=SINGEM AI Core
APP_ENV=development
APP_DEBUG=false
APP_VERSION=0.1.0
API_PREFIX=/ai
INTERNAL_TOKEN_HEADER=x-internal-token

# Seguranca interna
AI_INTERNAL_TOKEN=change-me

# Runtime local
AI_CORE_HOST=127.0.0.1
AI_CORE_PORT=8010
AI_CORE_RELOAD=false

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://singem_user:password@localhost:5432/singem
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Busca vetorial
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=hash-embedding-v1
EMBEDDING_DIMENSION=384
ENABLE_VECTOR_SEARCH=true

# Feature flags
AI_FEATURE_ENABLED=true
